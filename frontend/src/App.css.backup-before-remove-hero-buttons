* {
  box-sizing: border-box;
}

:root {
  --bg: #07120b;
  --bg-soft: #0d1b12;
  --panel: rgba(255, 255, 255, 0.94);
  --panel-dark: rgba(9, 25, 14, 0.9);
  --text: #102015;
  --muted: #637466;
  --muted-dark: #b6c9bb;
  --line: rgba(28, 77, 39, 0.12);
  --line-dark: rgba(209, 255, 219, 0.16);
  --green: #1f8f4d;
  --green-dark: #176b3a;
  --green-soft: #e8f8ed;
  --lime: #c8f26a;
  --warning: #ffbe3d;
  --danger: #e95b5b;
  --success: #22a75a;
  --shadow: 0 24px 70px rgba(0, 0, 0, 0.18);
  --radius-xl: 28px;
  --radius-lg: 22px;
  --radius-md: 14px;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-height: 100vh;
  font-family: Inter, Arial, sans-serif;
  background:
    radial-gradient(circle at top left, rgba(78, 183, 104, 0.35), transparent 30%),
    radial-gradient(circle at top right, rgba(200, 242, 106, 0.15), transparent 30%),
    linear-gradient(135deg, #061009 0%, #0c1a11 45%, #f3f7f0 45%, #f7faf5 100%);
  color: var(--text);
}

button,
input {
  font: inherit;
}

button {
  border: 0;
}

a {
  text-decoration: none;
}

.app-shell {
  position: relative;
  width: min(1240px, calc(100% - 32px));
  margin: 0 auto;
  padding: 24px 0 56px;
}

.background-orb {
  position: fixed;
  border-radius: 999px;
  filter: blur(20px);
  pointer-events: none;
  opacity: 0.55;
}

.orb-one {
  width: 320px;
  height: 320px;
  top: 80px;
  left: -120px;
  background: rgba(80, 222, 122, 0.18);
}

.orb-two {
  width: 260px;
  height: 260px;
  right: -90px;
  top: 240px;
  background: rgba(200, 242, 106, 0.18);
}

.topbar {
  position: sticky;
  top: 16px;
  z-index: 20;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14px;
  padding: 12px 14px;
  margin-bottom: 28px;
  background: rgba(5, 18, 10, 0.76);
  border: 1px solid var(--line-dark);
  border-radius: 999px;
  backdrop-filter: blur(16px);
  box-shadow: 0 18px 50px rgba(0, 0, 0, 0.18);
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
  color: #ffffff;
}

.brand-mark {
  width: 42px;
  height: 42px;
  display: grid;
  place-items: center;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--lime), #36d978);
  color: #0c1a11;
  font-weight: 950;
  text-transform: uppercase;
  letter-spacing: -0.06em;
}

.brand strong {
  display: block;
  font-size: 15px;
}

.brand span {
  display: block;
  margin-top: 2px;
  color: var(--muted-dark);
  font-size: 12px;
}

.topbar-actions {
  display: flex;
  align-items: center;
  gap: 10px;
}

.network-chip,
.ghost-link {
  display: inline-flex;
  align-items: center;
  height: 36px;
  padding: 0 14px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 800;
}

.network-chip {
  background: rgba(200, 242, 106, 0.14);
  color: #e5ff9a;
  border: 1px solid rgba(200, 242, 106, 0.28);
}

.ghost-link {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid var(--line-dark);
}

.hero {
  display: grid;
  grid-template-columns: 1.45fr 0.9fr;
  gap: 22px;
  margin-bottom: 22px;
}

.hero-main,
.contract-card,
.panel,
.metric-card {
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow);
}

.hero-main {
  position: relative;
  overflow: hidden;
  padding: 42px;
  min-height: 360px;
  background:
    radial-gradient(circle at top right, rgba(200, 242, 106, 0.22), transparent 34%),
    linear-gradient(135deg, rgba(12, 32, 18, 0.96), rgba(12, 50, 26, 0.92));
  color: #ffffff;
  border: 1px solid var(--line-dark);
}

.hero-main::after {
  content: "";
  position: absolute;
  width: 260px;
  height: 260px;
  right: -80px;
  bottom: -100px;
  border-radius: 999px;
  background: rgba(200, 242, 106, 0.14);
}

.eyebrow {
  margin: 0 0 14px;
  color: #d8ff88;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  font-weight: 900;
}

h1 {
  position: relative;
  z-index: 1;
  margin: 0;
  max-width: 780px;
  font-size: clamp(42px, 5.8vw, 72px);
  line-height: 0.96;
  letter-spacing: -0.055em;
}

.hero-text {
  position: relative;
  z-index: 1;
  margin: 22px 0 0;
  max-width: 760px;
  color: #d6e6d9;
  font-size: 18px;
  line-height: 1.7;
}

.hero-actions {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 28px;
}

.primary-link,
.secondary-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 46px;
  padding: 0 18px;
  border-radius: 999px;
  font-weight: 900;
}

.primary-link {
  background: linear-gradient(135deg, var(--lime), #39db78);
  color: #07120b;
}

.secondary-link {
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  border: 1px solid var(--line-dark);
}

.contract-card {
  padding: 26px;
  background: var(--panel);
  border: 1px solid var(--line);
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.card-kicker {
  width: fit-content;
  padding: 8px 12px;
  border-radius: 999px;
  background: var(--green-soft);
  color: var(--green-dark);
  font-size: 12px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.contract-card code,
.panel code,
.metric-card code {
  display: block;
  width: 100%;
  overflow-wrap: anywhere;
  word-break: break-word;
  padding: 12px;
  border-radius: 14px;
  background: #f0f8ee;
  border: 1px solid #dbead8;
  color: #18351f;
  font-family: Consolas, Monaco, monospace;
  font-size: 13px;
  line-height: 1.55;
}

.contract-meta {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 0;
  border-top: 1px solid var(--line);
}

.contract-meta span {
  color: var(--muted);
  font-size: 13px;
}

.contract-meta strong {
  color: var(--green-dark);
  font-size: 13px;
}

.text-link {
  color: var(--green-dark);
  font-weight: 900;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14px;
  margin-bottom: 22px;
}

.metric-card {
  padding: 18px;
  background: var(--panel);
  border: 1px solid var(--line);
}

.metric-card span {
  color: var(--muted);
  font-size: 12px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.metric-card strong {
  display: block;
  margin-top: 8px;
  font-size: 24px;
  letter-spacing: -0.03em;
}

.metric-card p {
  margin: 8px 0 0;
  color: var(--muted);
  font-size: 13px;
  line-height: 1.5;
}

.workspace-grid,
.evidence-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22px;
  margin-bottom: 22px;
}

.panel {
  padding: 24px;
  background: var(--panel);
  border: 1px solid var(--line);
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20px;
  margin-bottom: 2px;
}

.section-number {
  display: inline-flex;
  margin-bottom: 8px;
  color: var(--green);
  font-size: 12px;
  font-weight: 950;
  letter-spacing: 0.14em;
}

.panel h2 {
  margin: 0;
  font-size: 21px;
  letter-spacing: -0.02em;
}

.panel-header p {
  margin: 0;
  max-width: 280px;
  color: var(--muted);
  font-size: 13px;
  line-height: 1.55;
  text-align: right;
}

label {
  display: block;
  margin-bottom: -6px;
  color: #58705b;
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

input {
  width: 100%;
  border: 1px solid #d4e3d1;
  background: rgba(255, 255, 255, 0.74);
  border-radius: 14px;
  padding: 14px;
  color: var(--text);
  outline: none;
  transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
}

input:focus {
  background: #ffffff;
  border-color: rgba(31, 143, 77, 0.8);
  box-shadow: 0 0 0 4px rgba(31, 143, 77, 0.1);
}

.button-row,
.error-demo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

button {
  min-height: 44px;
  padding: 0 16px;
  border-radius: 14px;
  background: linear-gradient(135deg, #239550, #176b3a);
  color: #ffffff;
  cursor: pointer;
  font-weight: 900;
  box-shadow: 0 14px 28px rgba(31, 143, 77, 0.18);
  transition: transform 0.16s ease, box-shadow 0.16s ease, filter 0.16s ease;
}

button:hover {
  transform: translateY(-1px);
  filter: brightness(1.02);
  box-shadow: 0 18px 34px rgba(31, 143, 77, 0.23);
}

.secondary-button {
  background: #eef4eb;
  color: #17351f;
  border: 1px solid #d7e5d3;
  box-shadow: none;
}

.secondary-button:hover {
  box-shadow: none;
}

.wallet-kit-box {
  min-height: 48px;
  display: flex;
  align-items: center;
}

.data-row {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.data-row span {
  color: var(--muted);
  font-size: 12px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.state-panel pre {
  min-height: 220px;
}

pre {
  margin: 0;
  white-space: pre-wrap;
  overflow-wrap: anywhere;
  background: #07120b;
  color: #d9ffe0;
  border: 1px solid rgba(217, 255, 224, 0.13);
  border-radius: 18px;
  padding: 16px;
  font-size: 13px;
  line-height: 1.6;
  overflow: auto;
}

.status-pill {
  width: fit-content;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 42px;
  padding: 0 14px;
  border-radius: 999px;
  font-weight: 950;
}

.status-dot {
  width: 9px;
  height: 9px;
  border-radius: 999px;
}

.status-pill.idle {
  background: #eef2ee;
  color: #536356;
}

.status-pill.idle .status-dot {
  background: #8da092;
}

.status-pill.pending {
  background: #fff4ce;
  color: #7a5b00;
}

.status-pill.pending .status-dot {
  background: var(--warning);
}

.status-pill.success {
  background: #ddf8e6;
  color: #16642c;
}

.status-pill.success .status-dot {
  background: var(--success);
}

.status-pill.failed {
  background: #ffe4e4;
  color: #8b2626;
}

.status-pill.failed .status-dot {
  background: var(--danger);
}

.error-box {
  padding: 14px;
  border-radius: 16px;
  background: #fff0f0;
  color: #8b2626;
  border: 1px solid #ffd0d0;
  font-weight: 800;
  line-height: 1.55;
}

.empty-state {
  padding: 18px;
  border-radius: 18px;
  background: #f5faf3;
  border: 1px dashed #d7e6d3;
  color: var(--muted);
  line-height: 1.6;
}

.activity-panel,
.tx-panel {
  min-height: 300px;
}

.error-panel {
  grid-column: 1 / -1;
}

.activity-item {
  position: relative;
  display: grid;
  grid-template-columns: 18px 1fr;
  gap: 12px;
  padding: 14px 0;
  border-top: 1px solid var(--line);
}

.activity-item:first-of-type {
  border-top: 0;
  padding-top: 0;
}

.activity-marker {
  width: 10px;
  height: 10px;
  margin-top: 5px;
  border-radius: 999px;
  background: linear-gradient(135deg, var(--lime), var(--green));
  box-shadow: 0 0 0 5px rgba(31, 143, 77, 0.08);
}

.activity-item strong {
  font-size: 15px;
}

.activity-item p {
  margin: 6px 0 10px;
  color: var(--muted);
  line-height: 1.55;
  font-size: 14px;
}

@media (max-width: 1100px) {
  .metrics-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .hero,
  .workspace-grid,
  .evidence-grid {
    grid-template-columns: 1fr;
  }

  .error-panel {
    grid-column: auto;
  }

  .panel-header {
    flex-direction: column;
    gap: 8px;
  }

  .panel-header p {
    text-align: left;
    max-width: unset;
  }
}

@media (max-width: 720px) {
  body {
    background: #f7faf5;
  }

  .app-shell {
    width: min(100% - 20px, 1240px);
    padding-top: 12px;
  }

  .topbar {
    position: static;
    border-radius: 24px;
    align-items: flex-start;
    flex-direction: column;
  }

  .topbar-actions {
    width: 100%;
    justify-content: space-between;
  }

  .hero-main,
  .contract-card,
  .panel,
  .metric-card {
    border-radius: 22px;
  }

  .hero-main {
    padding: 28px;
  }

  h1 {
    font-size: 40px;
  }

  .hero-text {
    font-size: 16px;
  }

  .metrics-grid {
    grid-template-columns: 1fr;
  }

  .button-row,
  .error-demo-grid {
    flex-direction: column;
  }

  button,
  .primary-link,
  .secondary-link {
    width: 100%;
  }
}
